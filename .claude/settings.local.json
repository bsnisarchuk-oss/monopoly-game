{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit -m :*)",
      "Bash(git commit -m ':*)",
      "Bash(git stash:*)",
      "Bash(git -C u:/Monopoly log:*)",
      "Bash(git -C u:/Monopoly diff:*)",

      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(type:*)",
      "Bash(dir:*)",
      "Bash(cd:*)",
      "Bash(pwd)",

      "Bash(.venv/Scripts/python.exe:*)",
      "Bash(.venv/Scripts/pip.exe:*)",
      "Bash(.venv/Scripts/uvicorn.exe:*)",
      "Bash(.venv/Scripts/activate.bat)",
      "Bash(.venv\\Scripts\\python.exe:*)",
      "Bash(..\\.venv\\Scripts\\python.exe:*)",
      "Bash(u:/Monopoly/backend/.venv/Scripts/uvicorn.exe:*)",
      "Bash(python -m unittest:*)",
      "Bash(python -m pytest:*)",
      "Bash(python -m ruff:*)",
      "Bash(python -c :*)",
      "Bash(python -c ':*)",
      "Bash(uvicorn main:app:*)",

      "Bash(npm.cmd run:*)",
      "Bash(npm run:*)",
      "Bash(npx eslint:*)",
      "Bash(npx.cmd eslint:*)",

      "Bash(curl -s:*)",
      "Bash(curl -s -o:*)",
      "Bash(curl -s -X:*)",

      "Bash(start-backend.cmd)",
      "Bash(start-frontend.cmd)",
      "Bash(start.bat)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rmdir /s:*)",
      "Bash(del /s:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git checkout -- :*)",
      "Bash(git branch -D:*)",
      "Edit(.venv/**)",
      "Edit(node_modules/**)",
      "Edit(.git/**)",
      "Write(.venv/**)",
      "Write(node_modules/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/session-start.ps1"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/post-edit.ps1"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/pre-bash.ps1"
          }
        ]
      }
    ]
  }
}
